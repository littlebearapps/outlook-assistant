{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.littlebearapps/outlook-mcp",
  "description": "Outlook Assistant — MCP server with 20 tools for email, calendar, contacts, and settings via Microsoft Graph API.",
  "repository": {
    "url": "https://github.com/littlebearapps/outlook-mcp",
    "source": "github"
  },
  "version": "3.3.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@littlebearapps/outlook-mcp",
      "version": "3.3.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Azure AD application client ID",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "OUTLOOK_CLIENT_ID"
        },
        {
          "description": "Azure AD application client secret value",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "OUTLOOK_CLIENT_SECRET"
        }
      ]
    }
  ]
}
